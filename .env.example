GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Microsoft login / OneDrive sync
MICROSOFT_CLIENT_ID=your_microsoft_app_client_id_here
MICROSOFT_TENANT_ID=consumers

# Production settings
# Set to microsoft-only for the public website so local email-only login is hidden.
AUTH_MODE=local-and-microsoft
# Comma-separated origins that are allowed to start Microsoft login.
# Example: https://your-app.azurewebsites.net,https://your-domain.example
MICROSOFT_ALLOWED_ORIGINS=

PORT=3000
